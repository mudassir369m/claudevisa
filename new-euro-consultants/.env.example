# Admin credentials
ADMIN_EMAIL=admin@neweuroconsultants.com
ADMIN_PASSWORD=change-me-min-16-chars
SESSION_SECRET=change-me-openssl-rand-base64-32

# Public
NEXT_PUBLIC_SITE_URL=https://neweuroconsultants.com

# Storage — for Railway, set both to /app/data + /app/data/uploads
# and mount a Volume at /app/data
DATA_DIR=./data
UPLOAD_DIR=./public/uploads

# Runtime
NODE_ENV=production
PORT=3000
